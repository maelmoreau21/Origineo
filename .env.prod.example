# ──────────────────────────────────────
# Origineo — Production Environment
# ──────────────────────────────────────
# Copy this file to .env.prod and set secure values.
# NEVER commit .env.prod to version control.

# Database (REQUIRED — use a strong password)
DB_USER=origineo
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_NAME=origineo
DB_PORT=5432

# JWT Authentication (REQUIRED — use a 64+ char random string)
# Generate: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRATION=7d

# API
API_PORT=3001

# Frontend (set to your production URL)
NEXT_PUBLIC_API_URL=http://localhost

# Nginx ports
HTTP_PORT=80
HTTPS_PORT=443

# Node
NODE_ENV=production
