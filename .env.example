# ──────────────────────────────────────
# Origineo — Environment Variables
# ──────────────────────────────────────

# Database
DB_USER=origineo
DB_PASSWORD=origineo_secret_change_me
DB_NAME=origineo
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}

# JWT Authentication
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRATION=7d

# API
API_PORT=3001
API_HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Node
NODE_ENV=development
